# ── Postgres ──────────────────────────────────────────────────
POSTGRES_USER=finanzen
POSTGRES_PASSWORD=changeme
POSTGRES_DB=finanzen

# ── Backend ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finanzen:changeme@db:5432/finanzen
SECRET_KEY=change-this-to-a-random-256-bit-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CREDENTIALS_ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=change-this-too
NEXTAUTH_URL=http://localhost:3000
